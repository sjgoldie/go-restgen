meta {
  name: Create Order for Complete Flow
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/orders
  body: json
  auth: none
}

body:json {
  {
    "customer_name": "Bob",
    "total": 149.99
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.status: eq pending
}

script:post-response {
  bru.setVar("orderId2", res.body.id);
}
