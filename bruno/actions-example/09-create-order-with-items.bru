meta {
  name: Create Order with Items
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/orders
  body: json
  auth: none
}

body:json {
  {
    "customer_name": "Test Customer",
    "total": 150.00
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.customer_name: eq Test Customer
  res.body.status: eq pending
}

script:post-response {
  bru.setVar("orderWithItemsId", res.body.id);
}
