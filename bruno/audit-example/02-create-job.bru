meta {
  name: Create Job
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/jobs
  body: json
  auth: none
}

body:json {
  {
    "title": "Data Processing",
    "priority": 3
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.title: eq Data Processing
  res.body.status: eq pending
  res.body.priority: eq 3
}

script:post-response {
  bru.setVar("jobId", res.body.id);
}
