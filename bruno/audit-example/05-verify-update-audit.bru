meta {
  name: Verify Update Audit Log
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/audit-logs
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body[0].job_id: eq {{jobId}}
  res.body[0].operation: eq update
  res.body[0].old_data: contains pending
  res.body[0].new_data: contains running
}
