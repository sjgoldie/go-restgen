meta {
  name: Blogs - Create Blog (Bob)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/blogs
  body: json
  auth: bearer
}

auth:bearer {
  token: user:bob:user,admin
}

body:json {
  {
    "name": "Bob's Blog",
    "description": "Blog owned by Bob (admin)"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.author_id: eq bob
}

script:post-response {
  bru.setVar("bobBlogId", res.body.id);
}
