meta {
  name: Posts - Get Post As Editor
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/blogs/{{aliceBlogId}}/posts/{{alicePostId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: user:bob:user
}

assert {
  res.status: eq 200
  res.body.id: eq {{alicePostId}}
}

tests {
  test("Bob can access post because he's listed as editor", function() {
    expect(res.status).to.equal(200);
    expect(res.body.editor_id).to.equal("bob");
  });
}
