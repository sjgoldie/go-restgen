meta {
  name: Batch Update Non-existent - Fails
  type: http
  seq: 9
}

put {
  url: {{baseUrl}}/products/batch
  body: json
  auth: none
}

body:json {
  [
    {"id": 99999, "name": "Does Not Exist", "sku": "DNE001", "price": 1.00, "stock": 0}
  ]
}

assert {
  res.status: eq 404
  res.body.error: eq not_found
  res.body.message: eq Not Found
}
