meta {
  name: Add Small Variant
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/products/{{productWithVariantsId}}/variants
  body: json
  auth: none
}

body:json {
  {
    "name": "Small",
    "sku_suffix": "-S",
    "price_adjust": -5.00
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.product_id: eq {{productWithVariantsId}}
  res.body.name: eq Small
}
