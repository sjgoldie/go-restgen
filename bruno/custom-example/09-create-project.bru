meta {
  name: Create Project (Custom Create with Auto-Owner)
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/projects
  body: json
  auth: none
}

headers {
  Authorization: Bearer user:alice:user
}

body:json {
  {
    "name": "My Project",
    "description": "Test project"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.name: eq My Project
  res.body.owner_id: eq alice
}

script:post-response {
  bru.setVar("projectId", res.body.id);
}
