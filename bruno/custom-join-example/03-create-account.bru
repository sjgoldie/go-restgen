meta {
  name: Create Account
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/users/{{userId}}/accounts
  body: json
  auth: none
}

body:json {
  {
    "name": "Home Account"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.user_id: eq {{userId}}
  res.body.name: eq Home Account
}

script:post-response {
  bru.setVar("accountId", res.body.id);
}
