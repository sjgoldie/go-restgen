meta {
  name: Create Second Account with NMI002 Site
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/users/{{userId}}/accounts
  body: json
  auth: none
}

body:json {
  {
    "name": "Holiday House"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
}

script:post-response {
  bru.setVar("account2Id", res.body.id);
}
