meta {
  name: Get Image Metadata
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/posts/{{postId}}/images/{{imageId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.id: eq {{imageId}}
  res.body.post_id: eq {{postId}}
  res.body.filename: eq test-image.txt
  res.body.alt_text: eq Test image for Bruno
}

script:post-response {
  bru.setVar("downloadUrl", res.body.download_url);
}
