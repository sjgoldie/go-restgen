meta {
  name: Create User - Alice
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/users
  body: json
  auth: none
}

body:json {
  {
    "name": "Alice",
    "email": "alice@example.com"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.name: eq Alice
  res.body.email: eq alice@example.com
}

script:post-response {
  bru.setVar("aliceId", res.body.id);
}
