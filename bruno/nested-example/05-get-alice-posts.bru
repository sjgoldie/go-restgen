meta {
  name: Get All Posts for Alice
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/users/{{aliceId}}/posts
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body: isArray
}

tests {
  test("Alice should have 1 post", function() {
    expect(res.body).to.be.an('array');
    expect(res.body.length).to.equal(1);
    expect(res.body[0].user_id).to.equal(parseInt(bru.getVar("aliceId")));
  });
}
