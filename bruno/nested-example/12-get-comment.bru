meta {
  name: Get Comment (Valid Parent Chain)
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/users/{{aliceId}}/posts/{{alicePostId}}/comments/{{comment1Id}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.id: eq {{comment1Id}}
  res.body.post_id: eq {{alicePostId}}
  res.body.text: eq Great post, Alice!
}
