meta {
  name: Get Remaining Comments (Should Be 1)
  type: http
  seq: 16
}

get {
  url: {{baseUrl}}/users/{{aliceId}}/posts/{{alicePostId}}/comments
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body: isArray
}

tests {
  test("Post should now have 1 comment (after deletion)", function() {
    expect(res.body).to.be.an('array');
    expect(res.body.length).to.equal(1);
    expect(res.body[0].id).to.equal(parseInt(bru.getVar("comment2Id")));
  });
}
