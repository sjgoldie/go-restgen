meta {
  name: Create Product - Numeric Name (Name=123, Category=true)
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/products
  body: json
  auth: none
}

body:json {
  {
    "name": "123",
    "category": "true",
    "price": 999,
    "stock": 10,
    "active": true
  }
}

assert {
  res.status: eq 201
  res.body.name: eq "123"
  res.body.category: eq "true"
}
