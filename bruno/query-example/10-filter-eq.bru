meta {
  name: Filter EQ - Category equals Fruit
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/products?filter[Category]=Fruit
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.data: isArray
  res.body.data: length 2
}

tests {
  test("All results have Category = Fruit", function() {
    expect(res.body.data.every(p => p.category === "Fruit")).to.be.true;
  });
}
