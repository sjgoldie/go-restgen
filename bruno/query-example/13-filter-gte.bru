meta {
  name: Filter GTE - Price greater than or equal to 80
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/products?filter[Price][gte]=80
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body: isArray
  res.body: length 5
}

tests {
  test("All results have Price >= 80", function() {
    expect(res.body.every(p => p.price >= 80)).to.be.true;
  });
}
