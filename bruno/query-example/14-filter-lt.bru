meta {
  name: Filter LT - Price less than 80
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/products?filter[Price][lt]=80
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body: isArray
  res.body: length 2
}

tests {
  test("All results have Price < 80", function() {
    expect(res.body.every(p => p.price < 80)).to.be.true;
  });
}
