meta {
  name: Create Author - Alice
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/authors
  body: json
  auth: none
}

body:json {
  {
    "external_id": "alice",
    "name": "Alice",
    "email": "alice@example.com"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.name: eq Alice
}

script:post-response {
  bru.setVar("aliceAuthorId", res.body.id);
}
