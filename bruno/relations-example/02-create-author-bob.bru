meta {
  name: Create Author - Bob
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/authors
  body: json
  auth: none
}

body:json {
  {
    "external_id": "bob",
    "name": "Bob",
    "email": "bob@example.com"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.name: eq Bob
}

script:post-response {
  bru.setVar("bobAuthorId", res.body.id);
}
