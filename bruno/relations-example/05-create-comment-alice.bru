meta {
  name: Create Comment - Alice on her post
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/authors/{{aliceAuthorId}}/posts/{{alicePostId}}/comments
  body: json
  auth: bearer
}

auth:bearer {
  token: user:alice:user
}

body:json {
  {
    "text": "Alice's comment on her own post"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.owner_id: eq alice
}

script:post-response {
  bru.setVar("aliceCommentId", res.body.id);
}
