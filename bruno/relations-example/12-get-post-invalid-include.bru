meta {
  name: Get Post - Invalid Include (ignored)
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/posts/{{alicePostId}}?include=InvalidRelation
  body: none
  auth: bearer
}

auth:bearer {
  token: user:alice:user
}

assert {
  res.status: eq 200
  res.body.id: isDefined
  res.body.title: eq Alice's First Post
}

docs {
  Unknown relation names in ?include= are silently ignored
}
