meta {
  name: Get Author - Invalid Include (silently ignored)
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/authors/{{aliceAuthorId}}?include=InvalidRelation,Posts
  body: none
  auth: bearer
}

auth:bearer {
  token: user:admin:user,admin
}

assert {
  res.status: eq 200
  res.body.id: isDefined
  res.body.posts: isDefined
  res.body.posts.length: eq 1
}

docs {
  Invalid relation names are silently ignored, valid ones still work.
  Alice's author has 1 post (Alice's post).
}
