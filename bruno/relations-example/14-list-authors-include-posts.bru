meta {
  name: List Authors - Include Posts (as Admin)
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/authors?include=Posts
  body: none
  auth: bearer
}

auth:bearer {
  token: user:admin:user,admin
}

assert {
  res.status: eq 200
  res.body.length: eq 2
  res.body[0].posts: isDefined
}

docs {
  ?include=Posts works on list endpoints too
}
