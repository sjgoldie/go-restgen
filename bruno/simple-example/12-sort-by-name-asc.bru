meta {
  name: Sort Users by Name Ascending
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/users?sort=Name
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.data: isArray
  res.body.data: length 2
  res.body.data[0].name: eq Bob Smith
  res.body.data[1].name: eq Charlie Brown
}
