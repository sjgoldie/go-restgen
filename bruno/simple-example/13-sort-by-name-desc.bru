meta {
  name: Sort Users by Name Descending
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/users?sort=-Name
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.data: isArray
  res.body.data: length 2
  res.body.data[0].name: eq Charlie Brown
  res.body.data[1].name: eq Bob Smith
}
