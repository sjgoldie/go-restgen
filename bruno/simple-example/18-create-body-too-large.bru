meta {
  name: Create User Body Too Large
  type: http
  seq: 18
}

post {
  url: {{baseUrl}}/users
  body: json
  auth: none
}

body:json {
  {
    "name": "",
    "email": "toolarge@example.com"
  }
}

assert {
  res.status: eq 413
}

tests {
  test("Oversized JSON body returns 413", function() {
    expect(res.status).to.equal(413);
  });
}
