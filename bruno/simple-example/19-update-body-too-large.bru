meta {
  name: Update User Body Too Large
  type: http
  seq: 19
}

put {
  url: {{baseUrl}}/users/{{userId2}}
  body: json
  auth: none
}

body:json {
  {
    "name": "",
    "email": "toolarge@example.com"
  }
}

assert {
  res.status: eq 413
}

tests {
  test("Oversized JSON body on update returns 413", function() {
    expect(res.status).to.equal(413);
  });
}
