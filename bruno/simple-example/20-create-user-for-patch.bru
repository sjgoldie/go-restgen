meta {
  name: Create User for Patch
  type: http
  seq: 20
}

post {
  url: {{baseUrl}}/users
  body: json
  auth: none
}

body:json {
  {
    "name": "Patch Test User",
    "email": "patchtest@example.com"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.name: eq Patch Test User
  res.body.email: eq patchtest@example.com
}

script:post-response {
  bru.setVar("patchUserId", res.body.id);
}
