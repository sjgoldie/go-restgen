meta {
  name: Patch User Email Only
  type: http
  seq: 22
}

patch {
  url: {{baseUrl}}/users/{{patchUserId}}
  body: json
  auth: none
}

body:json {
  {
    "email": "patched@example.com"
  }
}

assert {
  res.status: eq 200
  res.body.id: eq {{patchUserId}}
  res.body.name: eq Patched Name
  res.body.email: eq patched@example.com
}
