meta {
  name: Create Organization A (Acme Corp)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/organizations
  body: json
  auth: bearer
}

auth:bearer {
  token: user:alice:org-a:user
}

body:json {
  {
    "id": "org-a",
    "name": "Acme Corp"
  }
}

assert {
  res.status: eq 201
  res.body.id: eq org-a
  res.body.name: eq Acme Corp
}
