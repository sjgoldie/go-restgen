meta {
  name: List Tasks - Own Tenant
  type: http
  seq: 19
}

get {
  url: {{baseUrl}}/projects/{{aliceProjectId}}/tasks
  body: none
  auth: bearer
}

auth:bearer {
  token: user:alice:org-a:user
}

assert {
  res.status: eq 200
  res.body.data: isArray
}

tests {
  test("Alice sees tasks under her project", function() {
    expect(res.body.data).to.be.an('array');
    expect(res.body.data.length).to.equal(1);
    expect(res.body.data[0].title).to.equal("Implement feature X");
    expect(res.body.data[0].org_id).to.equal("org-a");
  });
}
