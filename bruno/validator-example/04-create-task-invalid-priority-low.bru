meta {
  name: Create Task - Invalid Priority (too low)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/tasks
  body: json
  auth: none
}

body:json {
  {
    "title": "Invalid Task",
    "priority": 0
  }
}

assert {
  res.status: eq 400
  res.body.error: eq validation_error
  res.body.message: contains priority
}
