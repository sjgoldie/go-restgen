meta {
  name: Transition - In Progress to Completed (valid)
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/tasks/{{taskId}}
  body: json
  auth: none
}

body:json {
  {
    "title": "Test Task",
    "description": "A task for testing",
    "status": "completed",
    "priority": 3
  }
}

assert {
  res.status: eq 200
  res.body.status: eq completed
}
