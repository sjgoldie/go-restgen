meta {
  name: Create Task - For Cancel Flow
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/tasks
  body: json
  auth: none
}

body:json {
  {
    "title": "Task to Cancel",
    "description": "This task will be cancelled",
    "priority": 2
  }
}

assert {
  res.status: eq 201
  res.body.status: eq pending
}

script:post-response {
  bru.setVar("cancelTaskId", res.body.id);
}
