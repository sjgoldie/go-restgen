meta {
  name: Create Task - For Invalid Transition Test
  type: http
  seq: 14
}

post {
  url: {{baseUrl}}/tasks
  body: json
  auth: none
}

body:json {
  {
    "title": "Task for Invalid Transition",
    "priority": 1
  }
}

assert {
  res.status: eq 201
  res.body.status: eq pending
}

script:post-response {
  bru.setVar("invalidTransitionTaskId", res.body.id);
}
